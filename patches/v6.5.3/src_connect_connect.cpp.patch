+int send_simplyprint_no_return(const std::string &data){
+    bool timeout = true;
+    for (int i = 0; i < 100; i++) {
+        if (sp_conn_ready) { // Use .load() for atomic reads
+            sp_send_string = data;
+            sp_conn_ready = false; // Use .store() for atomic writes
+            timeout = false;
+            break;
+        }
+        vTaskDelay(pdMS_TO_TICKS(100)); // Delay for 1000 ms (1 second)
+    }
+    if (timeout){
+        return -1;
+    }
+    sp_data_to_send = true;
+    return 0;
+}
+
+std::string send_simplyprint(const std::string &data) {
+    bool timeout = true;
+    for (int i = 0; i < 100; i++) {
+        if (sp_conn_ready) { // Use .load() for atomic reads
+            sp_send_string = data;
+            sp_conn_ready = false; // Use .store() for atomic writes
+            timeout = false;
+            break;
+        }
+        vTaskDelay(pdMS_TO_TICKS(100)); // Delay for 1000 ms (1 second)
+    }
+
+    if (timeout) {
+        return "Could not send simplyprint. Timed out waiting for send_simplyprint_internal";
+    }
+
+    sp_data_to_send = true;
+    for (int i = 0; i < 100; i++) {
+        if (sp_conn_ready) {
+            sp_conn_ready = false;
+            return sp_response_error;
+        }
+        vTaskDelay(pdMS_TO_TICKS(100)); // Delay for 1000 ms (1 second)
+    }
+    sp_conn_ready = false;
+    return "";
+}
