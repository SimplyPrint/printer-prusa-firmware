+void Connect::send_simplyprint_internal(CachedFactory &conn_factory) {
+    if (!sp_data_to_send){
+        sp_conn_ready = true;
+        return;
+    }
+
+    if (!websocket.has_value()) {
+        return;
+    }
+
+    sp_conn_ready = false;
+    sp_data_to_send = false;
+
+    uint8_t buffer[MAX_RESP_SIZE];
+
+    memcpy(buffer, sp_send_string.c_str(), sp_send_string.size());
+
+    // Create and send the request
+    auto error = websocket->send(WebSocket::Text, true, buffer, sp_send_string.size());
+
+    if (error.has_value()) {
+        sp_response_error = http::to_str(error.value());
+    }
+    else {
+        sp_response_error = "";
+    }
+}
