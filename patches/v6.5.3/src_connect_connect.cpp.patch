+void Connect::send_simplyprint_internal(CachedFactory &conn_factory) {
+    if (!sp_data_to_send){
+        sp_conn_ready = true;
+        return;
+    }
+    sp_conn_ready = false;
+    sp_data_to_send = false;
+
+    // Get printer configuration
+    const auto &[config, cfg_changed] = printer.config();
+    conn_factory.refresh(config);
+
+    // Create and send the request
+    SimplyPrintRequest request(sp_send_string, config.token, &printer);
+    HttpClient http(conn_factory);
+    auto result = http.send(request);
+
+    auto *response = std::get_if<http::Response>(&result);
+
+    // Handle response
+    if (!response) {
+        sp_response_error = "HTTP Error, no response";
+        log_error(connect, sp_response_error.c_str());
+        return;
+    }
+
+    if (200 <= response->status && response->status < 300)
+        sp_response_error = "";
+    else {
+        sp_response_error = "HTTP Error while sending. Code: " + std::to_string(response->status);
+        log_error(connect, sp_response_error.c_str());
+    }
+}
