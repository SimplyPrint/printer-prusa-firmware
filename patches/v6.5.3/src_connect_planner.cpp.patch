+void Planner::command(const Command &command, const InitiateFirmwareUpdate &) {
+    if (printer.is_printing()) {
+        planned_event = Event { EventType::Rejected, command.id, nullopt, nullopt, nullopt, "Busy printing" };
+        return;
+    }
+
+    // Arm the bootloader (magic byte 0xBB + SFN in SRAM1) and reset. The
+    // SRAM1 region survives the reset; the bootloader picks up the file
+    // from /usb/ on the next boot.
+    data_exchange::set_reflash_bbf_sfn(ota::SFN);
+    HAL_Delay(10);
+    sys_reset();
+
+    // Not reached on a successful reset.
+    planned_event = Event { EventType::Rejected, command.id, nullopt, nullopt, nullopt, "Failed to reset" };
+}
+
 void Planner::command(const Command &command, const SendStateInfo &) {
     planned_event = { EventType::StateChanged, command.id };
 }
