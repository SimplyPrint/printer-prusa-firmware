--- /dev/null
+++ b/src/connect/ota_paths.hpp
@@ -0,0 +1,26 @@
+#pragma once
+
+namespace ota {
+
+// Reserved on-disk location for an OTA-downloaded firmware image.
+// The backend agrees to download incoming firmware updates to exactly this
+// path; the firmware deletes any stale file at this path before requesting
+// a new download, and the INITIATE_FIRMWARE_UPDATE handler hands the SFN
+// below to the bootloader.
+constexpr const char *USB_PATH = "/usb/_OTAFW.bbf";
+
+// Short File Name handed to data_exchange::set_reflash_bbf_sfn().
+//
+// HARD LIMIT: 13 bytes including the null terminator (12 visible chars max).
+// Enforced by the shared-RAM `bbf_sfn[13]` field that the bootloader reads
+// from SRAM1_BASE (0x20000000); longer names are silently truncated and
+// the bootloader will fail to locate the file. The 8.3 DOS short filename
+// form is required (uppercase ASCII, no spaces, at most 8 chars before the
+// dot + 3 after) so the LFN-to-SFN mapping is identity and the bootloader's
+// FAT resolution is deterministic.
+constexpr const char *SFN = "_OTAFW.BBF";
+
+static_assert(sizeof(SFN) <= 13,
+    "OTA SFN exceeds 13-byte bbf_sfn buffer");
+
+} // namespace ota
